# FinSight environment variables. Copy to .env and fill in. Never commit .env.

# ----- LLM APIs -----
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-proj-your-key-here  # for GPT-4o judge in Week 3 eval

# ----- Embeddings -----
VOYAGE_API_KEY=pa-your-voyage-key-here

# ----- Reranker -----
COHERE_API_KEY=your-cohere-key-here

# ----- Vector store -----
# Local dev uses Docker Compose Qdrant (http://localhost:6333). Leave QDRANT_URL blank for local.
QDRANT_URL=
QDRANT_API_KEY=

# For production deploy on Render, set these to your Qdrant Cloud cluster:
# QDRANT_URL=https://your-cluster.qdrant.tech
# QDRANT_API_KEY=your-qdrant-cloud-key

# ----- Observability -----
LANGSMITH_API_KEY=lsv2_your-langsmith-key-here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=finsight-dev

# ----- Model selection (defaults are fine; override for experiments) -----
ANTHROPIC_PRIMARY_MODEL=claude-sonnet-4-6
ANTHROPIC_ROUTER_MODEL=claude-haiku-4-5-20251001
VOYAGE_MODEL=voyage-finance-2
COHERE_RERANK_MODEL=rerank-english-v3.5

# ----- App config -----
ENV=development  # development | production
LOG_LEVEL=INFO
MAX_CHUNKS_RETURNED=5
RECENCY_BOOST_QUARTERS=2
RECENCY_BOOST_WEIGHT=0.15

# ----- DuckDB -----
DUCKDB_PATH=data/processed/finsight.duckdb

# ----- Cost controls -----
MAX_COST_PER_QUERY_USD=0.05  # hard cap. guardrail, not target. target is 0.005.
DAILY_API_BUDGET_USD=10.0    # circuit breaker during dev
